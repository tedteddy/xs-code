# DB9 - AI Agent 数据库
# 复制为 .env 后填入真实值；勿提交 .env
DATABASE_URL=
DB9_TOKEN=
DB9_DATABASE_ID=  # 首次运行后填入，用于复用已有数据库

# ── GitHub PAT（每 agent 独立账号，见 docs/agent-credentials.md）──
PM_GH_TOKEN=
UI_GH_TOKEN=
FRONTEND_GH_TOKEN=
CTO_GH_TOKEN=
QA_GH_TOKEN=

# ── Git 提交身份（sandbox 注入 GIT_AUTHOR_*，无需 git config）──
PM_GIT_USER=
PM_GIT_EMAIL=
UI_GIT_USER=
UI_GIT_EMAIL=
FRONTEND_GIT_USER=
FRONTEND_GIT_EMAIL=
CTO_GIT_USER=
CTO_GIT_EMAIL=
QA_GIT_USER=
QA_GIT_EMAIL=

# ── Linear API Key（UI agent 不需要，可留空）──────────────────────
PM_LINEAR_KEY=
FRONTEND_LINEAR_KEY=
CTO_LINEAR_KEY=
QA_LINEAR_KEY=

# Anthropic API Key（agent 运行必需，使用 proxy 代理）
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=

# BoxLite 本地沙箱（可选，USE_SANDBOX=1 时使用）
# BOXLITE_HOME=~/.boxlite

# BoxRun 远程模式（可选，替代本地 BoxLite）
# BOXRUN_API_URL=
# BOXRUN_API_TOKEN=

# Supabase（建网站时再填）
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
